GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
PORT=3001

# Casper testnet defaults. Replace these after deploying the contract.
VITE_API_URL=http://localhost:3001
# Use the local proxy in the browser to avoid CORS (Vite + server.js both proxy /casper-rpc).
VITE_CASPER_NODE_URL=/casper-rpc
VITE_CASPER_CHAIN_NAME=casper-test
VITE_CASPER_EXPLORER_URL=https://testnet.cspr.live
VITE_CASPER_CONTRACT_HASH=
VITE_CASPER_PAYMENT_AMOUNT=5000000000
VITE_CASPER_FUNDING_RECIPIENT=
